# Backend environment variables
# Copy this file to .env and fill in your values

# PostgreSQL connection (individual fields)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trello_clone
DB_USER=postgres
DB_PASSWORD=your_password_here

# Or use a connection string (takes precedence over individual fields)
# DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/trello_clone

# Server
PORT=3001

# CORS - set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173
